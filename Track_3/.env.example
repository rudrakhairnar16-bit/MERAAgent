# === Ollama LLM ===
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b

# === OpenTelemetry ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=mera-main-agent

# === SigNoz MCP Server ===
# The MCP server runs as a separate container (port 8000) from the SigNoz UI (port 8080)
# To find the MCP URL: docker ps and look for the "signoz-mcp" container
# Default Foundry MCP URL: http://localhost:8000/mcp
SIGNOZ_MCP_URL=http://localhost:8000/mcp

# Generate via: python scripts/setup_api_key.py
# Or manually: SigNoz UI → Settings → API Keys → Create PAT
SIGNOZ_API_KEY=

# === SigNoz Cloud (optional, for cloud-based ingestion) ===
SIGNOZ_INGESTION_KEY=
SIGNOZ_REGION=in
